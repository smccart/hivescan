{
  "name": "hivescan",
  "version": "0.1.0",
  "description": "Web-based terminal dashboard for managing Claude Code agents in a monorepo",
  "type": "module",
  "bin": {
    "hivescan": "src/cli.js"
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "start": "node src/cli.js",
    "dev": "node --watch src/cli.js",
    "postinstall": "node src/postinstall.cjs"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "agents",
    "terminal",
    "monorepo",
    "dashboard"
  ],
  "author": "Sean McCart",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smccart/hive.git"
  },
  "bugs": {
    "url": "https://github.com/smccart/hive/issues"
  },
  "homepage": "https://hivescan.dev",
  "dependencies": {
    "express": "^4.19.0",
    "node-pty": "^1.0.0",
    "ws": "^8.18.0"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "engines": {
    "node": ">=18"
  }
}
